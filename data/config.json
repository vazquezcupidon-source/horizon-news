{
  "version": "1.0",
  "enrichment_enabled": false,
  "filtering": {
    "ai_score_threshold": 3.0,
    "time_window_hours": 48
  },
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 512,
    "throttle_sec": 0,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 1,
    "languages": [
      "zh"
    ]
  },
  "language": "zh",
  "max_stories": 15,
  "min_score": 3,
  "site": {
    "enabled": false,
    "output_dir": "data/summaries",
